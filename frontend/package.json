{
  "name": "ems-desktop",
  "version": "1.0.2",
  "description": "EMS Desktop Application (Electron client)",
  "author": "ANWedage",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourcompany.emsdesktop",
    "productName": "EMS Desktop",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icons/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "ANWedage",
      "repo": "ems-project-",
      "releaseType": "release"
    },
    "releaseInfo": {
      "releaseNotes": "- Update License And Agreement"
    }
  }
}
